{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "dockerContext": "."
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS"
  },
  "services": {
    "web": {
      "type": "web",
      "environment": "production",
      "domains": []
    }
  }
}
